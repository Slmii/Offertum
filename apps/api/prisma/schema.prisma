// Offertum Prisma schema.
// - new `prisma-client` generator (Prisma 7+)
// - custom output to ../generated/prisma (gitignored)
// - pg driver adapter wires up the actual connection in src/prisma/prisma.service.ts.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Users are provisioned by Offertum admin via invitation; self-signup is disabled.
// An org can have many users. Roles exist but are informational until a feature enforces them
// (e.g. billing notifications, "can't delete the org while you're the last OWNER").
enum MembershipRole {
  OWNER
  MEMBER
  EXTERNAL
}

// Pre-Sentry stand-in. `warn`/`error`/`fatal` events from NestJS's Logger are
// persisted here in addition to the console.
enum LogLevel {
  FATAL
  ERROR
  WARN
  INFO
  DEBUG
}

// Per-org connection to an external mail provider (Gmail today; Microsoft Graph
// later). Independent of Auth.js's `Account` table because sign-in identity and
// inbox-sync identity are different concerns: a user may sign in via magic link and
// later connect their Gmail, OR sign in via Google and connect a *different* Gmail for
// inbox sync. Tokens are encrypted at rest in the same format as `Account` tokens —
// `v1:<base64(iv ‖ tag ‖ ciphertext)>` via `lib/crypto/token-encryption.ts`.
enum EmailProvider {
  GMAIL
  MICROSOFT
}

// Per-call log of every AI provider invocation.
// One row per `AIClient.generate(...)` call. Used for:
//  - **Replay**: rerun the same prompt against a different model when the prompt is iterated.
//    The `prompt` + `parsed` columns together let us reconstruct what the AI saw and what
//    it produced without needing to re-fetch the original `RawMessage`.
//  - **Cost tracking**: sum `promptTokens` + `completionTokens` per org per month.
//  - **Debugging**: filter by `status = 'schema_invalid'` to see which prompts produce
//    malformed outputs (signals a prompt that needs tightening).
//  - **Year-2 self-improvement**: when classifier accuracy improves later, re-run the new
//    prompt over historical `AICall` rows to see how many false negatives the old version
//    missed.
// We persist the full prompt + response as text — for a typical email + structured output,
// this is ~2-5kB per row. At 10k emails/month/org that's ~30MB/month — Postgres handles
// fine, and the value of being able to debug + replay is high.
enum AICallStatus {
  SUCCESS
  FAILED
  SCHEMA_INVALID
  TIMEOUT
}

// Materialized quote opportunity created from a classified-positive RawMessage.
// Uppercase per existing schema convention (see `MembershipRole`, `AICallStatus`,
// `EmailProvider`). Wire-format conversion to lowercase happens in
// `opportunity-status.mapper.ts`.
enum OpportunityStatus {
  NEW
  REPLIED
  WAITING
  COLD
  WON
  LOST
}

// Customer-signaled urgency on a quote request. Mirrors the extractor's Zod enum
// (see `extractor.types.ts`). Wire-format conversion to lowercase happens in
// `opportunity-urgency.mapper.ts`.
enum Urgency {
  EMERGENCY
  HIGH
  NORMAL
  LOW
}

// Reason an Opportunity was dismissed by the owner. Separate axis from
// `OpportunityStatus` so the workflow funnel (`lost`) and the
// classifier-feedback axis (`NOT_A_QUOTE`) never conflate.
//   - NOT_A_QUOTE : the classifier was wrong — this email wasn't a quote request.
//   - DUPLICATE   : same lead already exists as another Opportunity.
//   - SPAM        : the bulk-mail pre-filter missed it — promotes to filter fixture.
//   - OTHER       : free-text reason captured in the audit log.
enum DismissReason {
  NOT_A_QUOTE
  DUPLICATE
  SPAM
  OTHER
}

// Workflow state of a generated reply draft.
//   - PENDING_APPROVAL : AI generated, user hasn't touched it yet.
//   - EDITED           : user has modified the body (drives the edit-driven
//                        tone-playbook update prompt + the "AI accuracy" metric).
//   - SENT             : draft has been sent as a reply via Gmail / Graph.
enum ReplyDraftStatus {
  PENDING_APPROVAL
  EDITED
  SENT
}

// What kind of draft this is.
//   - REPLY    : a response to an inbound message — the original or a customer follow-up.
//                Default for everything generated previously.
//   - CHECK_IN : automatic "haven't heard back" follow-up generated by the
//                scheduler cron. Same body shape as a REPLY but tagged so the UI can
//                surface "Automatische follow-up" and so the cap-counter in the
//                scheduler doesn't double-count owner-initiated drafts.
enum ReplyDraftKind {
  REPLY
  CHECK_IN
}

// Workflow state of a generated quote draft (W10.2).
//   - DRAFT : generated by the line-item proposer, owner may still edit lines (W10.3).
//   - SENT  : the quote PDF has been attached to a reply and sent (W10.4).
enum QuoteDraftStatus {
  DRAFT
  SENT
}

// Provenance of a persisted quote line — mirrors the W10.1 proposer's wire
// `QuoteLineSource` ('catalog_match' | 'rule_applied' | 'inferred'). Drives the
// provenance display in the edit UI + the year-2 AI-accuracy metric.
//   - CATALOG_MATCH : matched to a CatalogItem; price + VAT came from that row.
//   - RULE_APPLIED  : produced by a firing PricingRule (hourly rate, surcharge,
//                     travel, discount, minimum-order). Number is engine-computed.
//   - INFERRED      : work the AI couldn't map to catalog/rule; price may be null
//                     until the owner sets one.
enum QuoteLineSource {
  CATALOG_MATCH
  RULE_APPLIED
  INFERRED
}

// Events the in-app + email notification system can surface to users.
//   - OPPORTUNITY_CREATED  : a new Opportunity was materialized from a classified-positive
//                            RawMessage.
//   - CUSTOMER_REPLY       : an inbound message landed on a tracked thread (status flipped
//                            REPLIED → NEW via attachFollowupMessage).
//   - OPPORTUNITY_AUTO_COLD: the auto-cold scheduler flipped a REPLIED opp to COLD after
//                            the silence-check-in budget ran out + coldAfterDays elapsed.
//                            In-app only — never email (avoids the inbox-loop of W6.2.5).
//   - WEEKLY_DIGEST        : aggregated Monday-morning summary (open opps, cold opps,
//                            pending follow-ups, estimated value).
enum NotificationEventType {
  OPPORTUNITY_CREATED
  CUSTOMER_REPLY
  OPPORTUNITY_AUTO_COLD
  WEEKLY_DIGEST
}

// Delivery channels for a notification. IN_APP writes a Notification row that the bell
// icon surfaces; EMAIL renders a Resend template and sends to the user's address. Slack
// + Teams are deferred to post-MVP.
enum NotificationChannel {
  IN_APP
  EMAIL
}

// Distinct categories of pricing rule the compile pass can emit. Each type has its
// own contract for `condition` + `effect` jsonb shape — validated at the service
// layer with Zod (see `pricing-playbook/dto/pricing-rule-condition.types.ts`).
// Adding a new type requires a Prisma migration AND a parallel update to the prompt
// + validator.
enum PricingRuleType {
  HOURLY_RATE
  MATERIAL_MARKUP
  VAT
  TRAVEL
  URGENCY
  DISCOUNT
  MINIMUM_ORDER
}

model User {
  id                    String    @id @default(uuid()) @db.Uuid
  email                 String    @unique
  name                  String?
  image                 String?
  emailVerified         DateTime?
  // Active organization for this user — session pins to this. Users with multiple
  // memberships switch via a future "switch org" mutation.
  currentOrganizationId String?   @db.Uuid
  // Per-user writing-style playbook. Free-form prose the user writes
  // in plain Dutch (greeting, sign-off, register, recurring phrases). Injected verbatim
  // into the reply-draft prompt when generating drafts on opportunities the user
  // is composing a reply for. Persists across orgs (multi-org: voice is the person's,
  // not the org's). NULL = use the generic Dutch neutral-professional baseline. Settable
  // from `/settings/writing-style`.
  tonePlaybookText      String?   @db.Text
  // When the playbook was last saved. Distinct from `User.updatedAt` so other
  // User-row updates (name change, etc.) don't trigger the "your writing style was
  // updated since this draft was generated" banner in the editor. NULL when the
  // user has never authored a playbook; set to NOW on every successful save; reset to
  // NULL when the playbook is cleared (text → empty).
  tonePlaybookUpdatedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  currentOrganization     Organization?            @relation("CurrentOrganization", fields: [currentOrganizationId], references: [id], onDelete: SetNull)
  memberships             Membership[]
  accounts                Account[]
  sessions                Session[]
  emailAccounts           EmailAccount[]
  dismissedOpportunities  Opportunity[]            @relation("OpportunityDismissedBy")
  assignedOpportunities   Opportunity[]            @relation("OpportunityAssignedTo")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
}

model Organization {
  id                        String   @id @default(uuid()) @db.Uuid
  name                      String
  // Per-org follow-up cadence + cap. The scheduler scans REPLIED opps
  // daily; a follow-up draft is generated when `(now − latestSentAt) ≥
  // followUpCadenceDays`, capped at `followUpMaxCount` automatic follow-ups per opp.
  // Defaults: every 4 days, max 2 follow-ups before
  // we stop nudging. The owner can set `followUpMaxCount = 0` to disable the
  // scheduler entirely for the org.
  followUpCadenceDays       Int      @default(4)
  followUpMaxCount          Int      @default(2)
  // Per-org auto-cold threshold. The `auto-cold-scheduler` cron flips a REPLIED
  // opportunity to COLD when the latest SENT draft is older than this many days AND
  // the silence-check-in budget (followUpMaxCount) has been exhausted. Default 14
  // days; 90-day ceiling. Set to 0 to disable the auto-cold cron entirely for the org.
  coldAfterDays             Int      @default(14)
  // ────────────────────────────────────────────────────────────────────────
  // Business details (W9.3) — appear on every quote PDF (W9.4) + invoice.
  // `name` above is the single source of truth for the customer-facing legal
  // name — edited at signup, re-edited on `/settings/business-details`.
  // (A previous design split this into a separate `companyName` column on the
  // hypothesis that the internal label and the legal entity name would diverge
  // for holding/operating splits; in practice they always matched and dropped
  // 2026-05-28.)
  // All other fields here are optional — the quote PDF degrades gracefully
  // when fields are missing (warns the owner up-front; never blocks send).
  // ────────────────────────────────────────────────────────────────────────
  // Country-specific company-registration number (NL: KvK, UK: Companies House,
  // DE: Handelsregister HRB, FR: SIREN, BE: KBO/BCE, etc.). Stored as free text
  // so the UI can vary the label per market without a schema change.
  companyRegistrationNumber String?
  // EU VAT identifier (NL/BE: BTW-nummer, DE: USt-IdNr, FR: TVA, etc.). The EU
  // VAT prefix already encodes the country; one column covers every member state.
  companyVatNumber          String?
  companyAddress            String?  @db.Text
  companyPhone              String?
  companyWebsite            String?
  // Default footer line printed on quote PDFs. Free-text, supports a couple of
  // lines (account number, terms reference, etc.).
  companyFooter             String?  @db.Text
  // Default payment-terms days printed on the quote ("Te voldoen binnen X
  // dagen na ontvangst van de factuur").
  defaultPaymentTermsDays   Int      @default(30)
  // Storage key for the company logo via `AttachmentStorage` (the same seam
  // ReplyDraftAttachment uses). NULL = no logo set; the PDF falls back to a
  // text-only header.
  logoStorageKey            String?
  // Optional image used as a quote-PDF letterhead/background. Same storage seam
  // as the logo; NULL means the neutral template background is used.
  letterheadStorageKey      String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  memberships             Membership[]
  invitations             Invitation[]
  currentMembers          User[]                   @relation("CurrentOrganization")
  subscription            Subscription?
  emailAccounts           EmailAccount[]
  opportunities           Opportunity[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  pricingPlaybook         PricingPlaybook?
  catalogItems            CatalogItem[]
  quoteDrafts             QuoteDraft[]
}

model Log {
  id        String   @id @default(uuid()) @db.Uuid
  level     LogLevel
  message   String   @db.Text
  context   String?
  stack     String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  // Correlation fields — populated once auth + request tracing land.
  requestId      String?
  userId         String? @db.Uuid
  organizationId String? @db.Uuid

  @@index([level, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([requestId])
}

model AICall {
  id               String       @id @default(uuid()) @db.Uuid
  // 'openai' | 'azure-openai' | 'mistral' | 'anthropic' (string, not enum, so adding a
  // provider doesn't require a Prisma migration).
  provider         String
  // The actual model identifier sent to the provider (e.g. 'gpt-4o-mini', 'gpt-4o',
  // 'mistral-large-latest', 'claude-sonnet-4-5'). Free text — providers add SKUs faster
  // than we'd want to migrate the schema for.
  model            String
  // The application-level intent: 'classifier' | 'extractor' | 'tone-learn' | 'reply-draft'
  // | etc. Driven by the caller — used for grouping in debug queries ("show me all
  // classifier calls that returned schema_invalid").
  purpose          String
  // The full prompt sent to the provider. May be large (~1-5kB typical). Stored verbatim
  // so we can replay against a different model later.
  prompt           String       @db.Text
  // Raw text response from the provider. Null if the call failed before a response was
  // received (network error, 5xx after retries exhausted).
  response         String?      @db.Text
  // Parsed structured output (Zod-validated). Null if the response wasn't valid against
  // the schema OR if no response was received. Lets services skip re-parsing.
  parsed           Json?
  status           AICallStatus
  errorMessage     String?      @db.Text
  promptTokens     Int?
  completionTokens Int?
  // Wall-clock duration of the call including retries. Useful for SLA tracking.
  latencyMs        Int
  // Correlation fields — auto-populated by `AICallLogger` from `RequestContext`
  // AsyncLocalStorage. May be null when the call originates outside a request (e.g.
  // an Inngest function running on a cron).
  requestId        String?
  userId           String?      @db.Uuid
  organizationId   String?      @db.Uuid
  createdAt        DateTime     @default(now())

  // Opportunities link to their originating classifier + extractor calls so we
  // can drill from a row in the product UI back to the exact prompt/response that
  // produced it. Two named relations because one Opportunity has two AICalls.
  classifiedOpportunities Opportunity[] @relation("OpportunityClassifiedAICall")
  extractedOpportunities  Opportunity[] @relation("OpportunityExtractedAICall")
  quoteDrafts             QuoteDraft[]  @relation("QuoteDraftAICall")
  // Reply-draft generation call. Named so it doesn't collide with the
  // classifier / extractor relations above.
  replyDrafts             ReplyDraft[]  @relation("ReplyDraftAICall")

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([purpose, status, createdAt(sort: Desc)])
  @@index([requestId])
}

// Schema dictated by @auth/prisma-adapter; field names use snake_case in places
// where the adapter expects them. Do not rename.
// `refresh_token` / `access_token` / `id_token` are encrypted at rest via the
// `withEncryptedAccountTokens` adapter wrapper (see modules/auth/encrypted-account-adapter.ts).
// Ciphertext format: `v1:<base64(iv ‖ tag ‖ ciphertext)>`. Decrypt with
// `decrypt(...)` from `lib/crypto/token-encryption.ts`.
model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Membership {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @db.Uuid
  organizationId String         @db.Uuid
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// Pending invitations to join an organization. Created by Offertum admin; redeemed by
// the recipient clicking a tokenized link sent via email. On redemption: creates the
// User row (if one doesn't already exist for that email) and a Membership.
model Invitation {
  id             String         @id @default(uuid()) @db.Uuid
  token          String         @unique
  email          String
  organizationId String         @db.Uuid
  role           MembershipRole @default(MEMBER)
  acceptedAt     DateTime?
  expiresAt      DateTime
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
}

// One row per Organization (1:1). Acts as the local "single source of truth" that we
// sync from Stripe via webhooks + the post-checkout /sync endpoint. Avoids the split-
// brain problem of trusting individual webhook payloads — every relevant event triggers
// a full re-fetch via `BillingService.syncFromStripe(customerId)`.
// `status` mirrors Stripe's Subscription.Status enum: "active" | "trialing" | "past_due"
// | "canceled" | "incomplete" | "incomplete_expired" | "unpaid" | "paused" — kept as
// String (not enum) so Stripe-side additions don't require a Prisma migration.
model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  organizationId         String    @unique @db.Uuid
  stripeCustomerId       String    @unique
  stripeSubscriptionId   String?   @unique
  status                 String?
  priceId                String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  // When set, Stripe has a `pending_update` on the subscription — a change (price
  // swap, quantity change made via the Portal that requires payment confirmation,
  // etc.) is staged and will be applied when the customer completes payment OR
  // expire on this timestamp. Surfaced in the `/billing/status` response so the
  // UI can render a "plan change scheduled / expires <date>" banner. NULL when
  // no pending update exists (the common case).
  pendingUpdateExpiresAt DateTime?
  paymentMethodBrand     String?
  paymentMethodLast4     String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Dedup ledger for Stripe webhook deliveries. Stripe retries the same `event.id`
// with exponential backoff when our endpoint doesn't 2xx within ~10s. Without a
// ledger, every retry would re-run `syncFromStripe` (idempotent on the local
// write side, but burns Stripe API calls + log spam + amplifies any concurrent-
// processing window). The handler inserts the row before processing — Postgres'
// unique constraint on `eventId` rejects duplicate deliveries; we catch the
// violation and respond 200 without processing.
model StripeWebhookEvent {
  id          String   @id @default(uuid()) @db.Uuid
  // `event.id` from Stripe (`evt_...`). The unique constraint is the dedup
  // primitive — every webhook delivery races to insert this row.
  eventId     String   @unique
  // Event type for forensics / log filtering (`customer.subscription.updated`,
  // `invoice.paid`, etc.). Not part of the dedup key.
  type        String
  processedAt DateTime @default(now())

  @@index([type, processedAt(sort: Desc)])
}

model EmailAccount {
  id                      String        @id @default(uuid()) @db.Uuid
  organizationId          String        @db.Uuid
  // The user who connected this mailbox. Useful for audit ("who linked this account")
  // and a future "only the connector or an OWNER can disconnect" guard. ON DELETE SET
  // NULL so removing the user doesn't drop the org's inbox connection silently.
  userId                  String?       @db.Uuid
  provider                EmailProvider
  // Provider's stable account identifier (Gmail: the resource id / sub; Graph: oid).
  providerAccountId       String
  // The mailbox address itself, for display purposes only. Don't key off this — users
  // can alias addresses to the same Gmail account.
  email                   String
  // Granted OAuth scopes (space-separated). Compared against required scopes on each
  // start-of-sync; a mismatch triggers a re-consent prompt instead of a silent fail.
  scope                   String        @db.Text
  accessToken             String        @db.Text
  refreshToken            String        @db.Text
  // When the current access token expires (server time). Lazy-refreshed by the Gmail
  // service when the call is within ~60s of expiry. Null on first connect until the
  // first successful exchange writes it.
  accessTokenExpiresAt    DateTime?
  // Gmail's `historyId` from the last successful list/sync. Used for delta
  // sync via `users.history.list`. Null until backfill records one.
  historyId               String?
  // Microsoft Graph's `@odata.deltaLink` from the last successful `/me/messages/delta`
  // page walk. Stored as the FULL URL Graph returns (includes a server-issued
  // token), not a synthetic short form. Null until backfill records one. On Graph this
  // serves the same purpose as `historyId` for Gmail — only one of the two will be set
  // per row, based on `provider`.
  deltaLink               String?       @db.Text
  // Push subscription expiry — applies to BOTH providers but the TTLs differ:
  //   - Gmail: 7-day TTL, daily cron renews rows with < 24 h remaining.
  //   - Microsoft Graph: 3-day TTL, twice-daily cron with the same 24 h-remaining buffer.
  // Semantically distinct from the original "watchExpiresAt" since Graph uses
  // "subscription" terminology, but keeping the column name avoids a destructive
  // migration.
  watchExpiresAt          DateTime?
  // Microsoft Graph subscription resource ID. Returned by POST /subscriptions.
  // Required for PATCH-based renewal and for DELETE on disconnect. Null when provider
  // is GMAIL or before the subscription has been registered.
  subscriptionId          String?
  // Microsoft Graph `clientState` — shared secret echoed back on every push delivery.
  // We generate it at subscription-create time (random 32 bytes hex), store encrypted
  // here, and compare equality on every incoming push to authenticate it. Graph's
  // equivalent of Pub/Sub's JWT (simpler, no JWKS/JWT crypto). Stored encrypted
  // because leakage would let anyone post fake notifications and trigger delta-syncs.
  // Null for Gmail rows.
  subscriptionClientState String?       @db.Text
  // Soft-disconnect timestamp. When non-null, the user has clicked
  // Disconnect: we stop the Pub/Sub watch / Graph subscription, revoke the OAuth
  // refresh token at the provider, and set this column instead of hard-deleting the
  // row. The row stays so `RawMessage` / `Opportunity` history is preserved (those
  // FKs cascade-delete and would wipe months of pipeline work otherwise). Re-
  // connecting the same provider account upserts on the existing row + clears this.
  // All "is connected" lookups filter `disconnectedAt: null`.
  disconnectedAt          DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  rawMessages   RawMessage[]
  opportunities Opportunity[]

  // One row per (org, provider, mailbox). Reconnecting the same Gmail account should
  // upsert this row, not create a duplicate.
  @@unique([organizationId, provider, providerAccountId])
  @@index([organizationId])
}

// Raw provider message payload, pre-classification.
// Populated by the backfill worker (Inngest job) on initial connect, and by the
// push-notification handlers thereafter. NOT a long-lived store: once the pipeline
// classifies + extracts, `RawMessage` is mainly the source-of-truth for re-extraction
// (year-2 self-improvement story). Keep the full provider JSON in `raw` rather than
// shredding into typed columns — Gmail / Graph payloads are nested and we'd lose info.
model RawMessage {
  id                  String    @id @default(uuid()) @db.Uuid
  emailAccountId      String    @db.Uuid
  // Denormalized for tenant-scoped queries (so we don't always need to JOIN through
  // EmailAccount to enforce org isolation).
  organizationId      String    @db.Uuid
  providerMessageId   String
  threadId            String?
  // ISO timestamp from provider (Gmail: `internalDate` in ms; Graph: `receivedDateTime`).
  internalDate        DateTime
  subject             String?
  fromEmail           String?
  fromName            String?
  // Full provider payload as JSON. Schema varies by provider.
  raw                 Json
  fetchedAt           DateTime  @default(now())
  // Classifier/extractor fields. Nullable until the pipeline runs.
  isQuoteRequest      Boolean?
  classifiedAt        DateTime?
  // Set when the should-reply classifier flagged this message as a conversation
  // closer ("Bedankt, tot dan!" etc.) and the pipeline deliberately skipped draft
  // generation. Surfaced on the detail view's customer-replies chip.
  wasDetectedAsCloser Boolean   @default(false)
  // Thread reconstitution. Set when this RawMessage is attached to an existing
  // Opportunity (e.g., a customer reply on a thread we've already classified). NULL
  // for messages that haven't been linked, including all bulk-mail-filtered and
  // classifier-negative rows. The 1:N inverse on Opportunity is `threadMessages`.
  // Note: the ORIGINATING message of an Opportunity is reachable via
  // `Opportunity.rawMessageId` (1:1, unique). This nullable FK is the *follow-up*
  // link — historical rows have it NULL until a future reply lands on the same
  // threadId and we attach it. No backfill on existing rows; only new follow-ups
  // populate this column. SetNull on delete so AICall retention purges don't cascade.
  opportunityId       String?   @db.Uuid

  emailAccount         EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  opportunity          Opportunity? @relation("OpportunityOriginatingRawMessage")
  threadOpportunity    Opportunity? @relation("OpportunityThreadMessages", fields: [opportunityId], references: [id], onDelete: SetNull)
  // Inverse for `Opportunity.latestCustomerRawMessage`. Same RawMessage can be the
  // originating AND the latest-customer (single-message threads) or only the
  // latest-customer (followup message later in the thread).
  latestForOpportunity Opportunity? @relation("OpportunityLatestCustomerRawMessage")

  // Idempotency on backfill + delta sync: re-fetching the same message ID is a no-op.
  @@unique([emailAccountId, providerMessageId])
  @@index([organizationId, internalDate(sort: Desc)])
  @@index([opportunityId])
}

// The user-facing quote request entity. RawMessage remains the immutable source
// payload; Opportunity is the indexed, editable workflow record.
model Opportunity {
  id                         String            @id @default(uuid()) @db.Uuid
  organizationId             String            @db.Uuid
  emailAccountId             String            @db.Uuid
  // Originating customer message — the OLDEST non-self positive in the thread, set
  // by `processThreadGroup`'s oldest-first picker. Drives the "Originele e-mail" UI
  // panel + the extractor's input. `@unique` since each RawMessage can only originate
  // one Opportunity (idempotency on backfill re-runs).
  rawMessageId               String            @unique @db.Uuid
  // Latest inbound (customer-side) message attached to this opp's thread. Distinct
  // from `rawMessageId` so we can keep two independent semantics on one row:
  //   - originating = drives "Originele e-mail" display + AI extractor (oldest)
  //   - latest customer = drives RFC 2822 threading headers (`In-Reply-To` /
  //     `References`) on outbound sends + the AI draft-generator's prompt input.
  // Set to `rawMessageId` at opp creation (the originating IS the only customer
  // message at that point). Bumped forward by `attachFollowupMessage` /
  // `attachThreadMessage` whenever a NEWER customer-side message lands on the
  // thread. Own-mailbox outbound messages (`isOrgOwnSender = true`) do NOT update
  // this pointer — they're our replies, not the customer's. `onDelete: SetNull`
  // so deleting the RawMessage (rare; usually retention purge) doesn't cascade-
  // delete the opp.
  // `@unique` because each RawMessage belongs to at most one opportunity's thread
  // (via `RawMessage.opportunityId`) and can therefore be the latest-customer of
  // at most one opp — Prisma requires unique on the defining side of a 1:1.
  latestCustomerRawMessageId String?           @unique @db.Uuid
  status                     OpportunityStatus @default(NEW)
  // `provider/model` of the call that produced this opportunity's structured fields
  // (the extractor call). E.g. `openai/gpt-4o`, `azure-openai/gpt-4o-mini`. Kept as
  // String because providers add SKUs faster than we'd want to migrate the schema.
  aiProvider                 String
  // FK to the AICall row that ran the classifier for this RawMessage. Nullable because
  // the AICall log persist is best-effort — a DB hiccup on the AICall write shouldn't
  // block the Opportunity from being created. SetNull on delete so an AICall retention
  // policy that purges old rows doesn't cascade-delete real product data.
  classifiedAiCallId         String?           @db.Uuid
  // FK to the AICall row that ran the extractor for this RawMessage. Same nullability +
  // SetNull semantics as `classifiedAiCallId`.
  extractedAiCallId          String?           @db.Uuid
  classifierConfidence       Float?
  classifierReason           String?           @db.Text
  customerName               String?
  customerEmail              String?
  address                    String?           @db.Text
  requestType                String
  urgency                    Urgency
  customerDeadline           DateTime?
  customerAppointment        DateTime?
  deliverableHints           Json
  // Soft-disable (NOT hard-delete) when the owner marks this opportunity as
  // not a real lead. Preserving the row keeps `classifiedAiCallId` reachable for the
  // year-2 self-improvement story (audit trail) and lets the admin precision
  // tile compute `1 − dismissed(NOT_A_QUOTE) / total`.
  // Invariant enforced in DB via raw SQL CHECK: (dismissedAt IS NULL) = (dismissReason IS NULL).
  dismissedAt                DateTime?
  dismissReason              DismissReason?
  dismissedById              String?           @db.Uuid
  // Per-opp assignment. NULL = unassigned (any org member can pick it up). When set,
  // the assignee is the "owner" of the workflow on this opp — get filtered "Aan mij
  // toegewezen" view, and a future "assignee changed"-style notification surface.
  // ON DELETE SET NULL so deleting a user doesn't cascade-delete their opps.
  assignedToUserId           String?           @db.Uuid
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailAccount             EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  rawMessage               RawMessage   @relation("OpportunityOriginatingRawMessage", fields: [rawMessageId], references: [id], onDelete: Cascade)
  latestCustomerRawMessage RawMessage?  @relation("OpportunityLatestCustomerRawMessage", fields: [latestCustomerRawMessageId], references: [id], onDelete: SetNull)
  threadMessages           RawMessage[] @relation("OpportunityThreadMessages")
  classifiedAiCall         AICall?      @relation("OpportunityClassifiedAICall", fields: [classifiedAiCallId], references: [id], onDelete: SetNull)
  extractedAiCall          AICall?      @relation("OpportunityExtractedAICall", fields: [extractedAiCallId], references: [id], onDelete: SetNull)
  dismissedBy              User?        @relation("OpportunityDismissedBy", fields: [dismissedById], references: [id], onDelete: SetNull)
  assignedTo               User?        @relation("OpportunityAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  // 1:N drafts (formerly 1:1 via `@unique` on `ReplyDraft.opportunityId`). One opp
  // can have multiple drafts: the original + one or more follow-ups composed after a
  // customer reply or via the "Concept-vervolg opstellen" button. Read sites use
  // `orderBy: createdAt desc, take: 1` to surface the *current* draft.
  replyDrafts              ReplyDraft[]
  quoteDrafts              QuoteDraft[]

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([organizationId, customerDeadline])
  @@index([emailAccountId])
  @@index([classifiedAiCallId])
  @@index([extractedAiCallId])
  // Index supporting the dismissedAt filter on list queries. The default list path
  // benefits from a partial index (WHERE "dismissedAt" IS NULL) which Prisma's schema
  // language doesn't express — it's appended to the generated migration SQL by hand:
  //   CREATE INDEX "Opportunity_org_createdAt_active_idx"
  //     ON "Opportunity" ("organizationId", "createdAt" DESC) WHERE "dismissedAt" IS NULL;
  @@index([organizationId, dismissedAt])
  // Supports the "Toegewezen aan mij" list filter — common path is small (one user's
  // open opps), so a composite over (assignedToUserId, organizationId) keeps the lookup
  // an index-only scan.
  @@index([assignedToUserId, organizationId])
}

// AI-generated reply draft for an Opportunity. Idempotency on initial generation is
// enforced by checking for an existing draft before creating a new one. `originalBody`
// keeps the pristine AI output so we can compute the diff against `body` when the owner
// sends, and surface the "Wil je dit aan je schrijfstijl toevoegen?" prompt.
model ReplyDraft {
  id              String           @id @default(uuid()) @db.Uuid
  // Dropped `@unique`. An opp now has 1:N drafts: the original plus one or
  // more follow-ups created when a customer reply lands on the same thread, or when
  // the owner clicks "Concept-vervolg opstellen" on a SENT draft. Read sites pick the
  // current draft via `orderBy: createdAt desc, take: 1`; the editability gate keeps
  // mutations on the latest non-SENT row.
  opportunityId   String           @db.Uuid
  // The original AI-generated body. Never mutated after creation — used as the
  // baseline for the edit-detection diff and as a "revert to AI version"
  // affordance in the editor if we want one later.
  originalBody    String           @db.Text
  // The current body. Starts == originalBody; mutates as the user edits.
  body            String           @db.Text
  status          ReplyDraftStatus @default(PENDING_APPROVAL)
  // Distinguishes scheduler-generated "haven't heard back" check-ins from
  // owner-initiated replies. Drives the "Automatische follow-up" chip in the history
  // panel and lets the scheduler count its own work without double-counting owner
  // sends. Default REPLY so every pre-existing row + every owner-driven future row
  // stays typed correctly without a backfill.
  kind            ReplyDraftKind   @default(REPLY)
  // Flips true on first user edit so the dashboard can compute
  // "% of AI drafts sent without modification."
  wasEditedByUser Boolean          @default(false)
  // FK to the AICall that produced the draft. Same SetNull semantics as the
  // classifier / extractor links so an AICall retention purge doesn't cascade
  // into product data. Null when the AICall persist failed (best-effort).
  aiCallId        String?          @db.Uuid
  // Timestamp the draft was sent. Null until then. Separate from `status`
  // so we can query "drafts sent in window X" without parsing audit logs.
  sentAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  opportunity Opportunity            @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  aiCall      AICall?                @relation("ReplyDraftAICall", fields: [aiCallId], references: [id], onDelete: SetNull)
  attachments ReplyDraftAttachment[]

  // Fast "latest draft for this opp" lookup. Replaces the implicit index that
  // the dropped `@unique([opportunityId])` provided. Critical for the editor reads
  // and the editability gate which run on every detail-view load.
  @@index([opportunityId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([aiCallId])
}

// Attachments staged on a reply draft. Persisted alongside the draft
// so a regenerate doesn't lose them and a read-only SENT view can list what went out.
// Binary lives in the configured storage backend (local FS in dev, DigitalOcean Spaces
// in prod); this table only holds metadata. Cascade-delete on the draft cleans up the
// row but NOT the stored blob — the service layer purges the backend file before it
// hands off to Prisma (best-effort: orphaned blobs on the local driver are harmless
// noise and the prod driver handles them via a separate sweeper).
model ReplyDraftAttachment {
  id            String   @id @default(uuid()) @db.Uuid
  replyDraftId  String   @db.Uuid
  // Display name, taken from the upload. Sanitized at write-time (path separators
  // stripped) so it's safe to surface in the UI verbatim and to use in the Content-
  // Disposition header on send.
  filename      String
  contentType   String
  sizeBytes     Int
  // Opaque storage-backend pointer. Local FS driver = relative path under the
  // configured root (`<replyDraftId>/<uuid>-<filename>`). Spaces driver = the object
  // key (`reply-drafts/<replyDraftId>/<uuid>-<filename>`). The driver column below
  // captures which backend produced this key so a future migration can know what
  // to migrate FROM.
  storageKey    String   @db.Text
  storageDriver String   @default("local")
  createdAt     DateTime @default(now())

  replyDraft ReplyDraft @relation(fields: [replyDraftId], references: [id], onDelete: Cascade)

  @@index([replyDraftId])
}

// One in-app notification row. Bell icon in the header queries the
// most-recent N rows for the current user. Rows are kept indefinitely; future
// pruning lives in a separate sweeper if the table grows uncomfortably.
//
// `link` is a relative web path the bell-dropdown deep-links to (e.g.
// `/opportunities/<uuid>`). `metadata` is a small Json bag for renderer-specific
// fields (e.g. customer name, deadline) so the dropdown can show a richer
// preview without re-fetching the opportunity.
model Notification {
  id             String                @id @default(uuid()) @db.Uuid
  userId         String                @db.Uuid
  organizationId String                @db.Uuid
  eventType      NotificationEventType
  title          String
  body           String                @db.Text
  link           String?
  metadata       Json?
  readAt         DateTime?
  createdAt      DateTime              @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Unread-first listing for the bell icon: filters by user + readAt IS NULL
  // ordered by createdAt DESC. Composite index covers both legs.
  @@index([userId, readAt, createdAt(sort: Desc)])
  @@index([organizationId])
}

// Per-user × per-org × per-event × per-channel opt-in toggle. Missing rows are
// treated as default-enabled at read time (see NotificationService.shouldDeliver).
// Inserting a row is only required to opt OUT — saves a write per (user, event,
// channel) tuple on every signup.
//
// Org-scoped because a user could be in multiple orgs and want different
// noise levels in each (e.g. work org: noisy, personal org: silent).
model NotificationPreference {
  id             String                @id @default(uuid()) @db.Uuid
  userId         String                @db.Uuid
  organizationId String                @db.Uuid
  eventType      NotificationEventType
  channel        NotificationChannel
  enabled        Boolean               @default(true)
  updatedAt      DateTime              @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, eventType, channel])
  @@index([organizationId])
}

// The owner writes pricing logic as free-form prose in
// `playbookText`; an LLM compile pass (`pricing-playbook-compile` Inngest function)
// turns that prose into typed `PricingRule` rows the quote pipeline evaluates
// deterministically. Free-form is the SOURCE OF TRUTH — re-compiling on changed
// `playbookText` replaces non-manually-overridden rules; manually edited rules
// (`PricingRule.manualOverride = true`) survive compile passes intact.
// 1:1 with Organization — there's only one current pricing playbook per org. Draft
// versioning was deliberately deferred (the `manualOverride` mechanism covers the
// "the AI got it wrong, let me fix THIS rule" case without needing version history).
// Lazy-created on first read (no migration data step required).
model PricingPlaybook {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @unique @db.Uuid
  // Free-form prose. The owner's pricing logic
  // in their own words. UI is a single textarea; markdown is rendered in the
  // preview but stored as raw text so a future schema bump can re-interpret
  // without lossy reverse-engineering.
  playbookText   String    @default("") @db.Text
  // Timestamp of the last completed compile pass. NULL = never compiled (fresh
  // org or playbookText is still empty). The UI uses this to show compile state
  // (compiling vs. ready).
  compiledAt     DateTime?
  // sha256 of `playbookText` at compile time. The compile function no-ops when the
  // hash matches (idempotency on Inngest retries + on rapid-save flurries that
  // collapse into one debounced compile event).
  compiledHash   String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rules        PricingRule[]
}

model PricingRule {
  id                 String          @id @default(uuid()) @db.Uuid
  pricingPlaybookId  String          @db.Uuid
  ruleType           PricingRuleType
  // Structured matcher — the rule engine evaluates this against opp + line context.
  // Shape varies per `ruleType` (e.g. `{ category: "plumbing" }` for HOURLY_RATE,
  // `{ jurisdiction: "construction" }` for BTW). Validated by Zod at the service.
  // A DB CHECK constraint (appended in the migration) enforces that the blob is a
  // JSON object — anything more granular lives at the application layer.
  condition          Json
  // Structured payload the engine applies when `condition` matches. Always carries
  // a `type` discriminator field — DB CHECK constraint rejects rows where it's NULL
  // or missing (see migration). Example: `{ type: "rate_eur_per_hour", value: 95 }`.
  effect             Json
  // Higher priority wins on conflict. Manual overrides bump effective priority by
  // a fixed amount at engine time (see `rule-engine.ts`) so an owner-edited rule
  // beats an LLM-generated rule on the same `(ruleType, condition)` slot.
  priority           Int             @default(0)
  active             Boolean         @default(true)
  // Human-readable label for the review UI. The compile pass emits this from the
  // source prose (e.g. "Plumbing work: €95/hour"); the owner can edit it.
  description        String          @db.Text
  // Free-text qualifier that captures conditions the structured `condition` enum
  // (category / urgency / jurisdiction / lineKind) can't express — e.g.
  // "renovaties van woningen ouder dan 2 jaar", "opdrachten boven €5.000",
  // "klanten ik al 5 jaar ken". When present, the quote pipeline asks the AI at
  // quote time whether the narrative applies to the opportunity context, and
  // only commits the rule's effect when the AI confirms. NULL = the structured
  // `condition` is the complete match; no AI verification needed.
  conditionNarrative String?         @db.Text
  // Flips to true the moment an owner edits this rule via the review UI (W11.4).
  // Subsequent compile passes leave manually-edited rules alone — they get
  // `active: false` if their source sentence vanished from `playbookText` but
  // never get overwritten outright.
  manualOverride     Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  pricingPlaybook PricingPlaybook @relation(fields: [pricingPlaybookId], references: [id], onDelete: Cascade)

  // The engine's most common access pattern: load all active rules for an org's
  // playbook, sort by priority DESC. Composite index keeps that scan fast.
  @@index([pricingPlaybookId, active, priority(sort: Desc)])
}

// Owner-maintained catalog of products / services that show up as suggested line
// items when the AI proposer (W10.1) drafts a quote. Catalog hit + pricing rules
// (W11) together produce the deterministic part of the quote; the LLM fallback
// only fires for line items neither covered.
//
// Org-scoped, soft-disable via `active` so historical quotes can still resolve
// the catalog item even after the owner stops offering it. Hard delete is also
// allowed because v1 doesn't track which quotes referenced which catalog item
// (W10.2 will denormalize the price/name into the QuoteLineItem so deletes are
// safe without breaking history).
model CatalogItem {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  // Customer-facing name printed verbatim on the quote PDF. In the owner's
  // language — Dutch for now, translatable when locale lands.
  name            String
  // Optional longer prose. Rendered under the name on the PDF when present.
  description     String?  @db.Text
  // Default unit price in EUR. Decimal(10, 2) caps at €99 999 999.99 — comfortable
  // for any single-line-item price; the W10 proposer can still override per quote.
  defaultPriceEur Decimal  @db.Decimal(10, 2)
  // Default VAT rate as an integer percentage (0 / 9 / 21). Matches the
  // PricingRule.vat shape so the engine can apply the right bracket. Per-line
  // overrides at quote time still possible.
  defaultVatRate  Int      @default(21)
  // Owner-set SKU / article code. Optional, NOT unique (different orgs can
  // share the same SKU; same org may want to reuse an SKU for variants).
  sku             String?
  // Unit label printed next to qty on the PDF. Free-text for now ("piece",
  // "hour", "m2", "m", "kg", "stuks", "uur"). Tighten to an enum in v2 if
  // owners actually fight over the values.
  unit            String   @default("piece")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Default list-view query: active items first, then newest. The composite
  // covers both the catalog page (any active item) AND the AI proposer's
  // "find candidates for THIS opp" (filter by name/SKU substring + active).
  @@index([organizationId, active, createdAt(sort: Desc)])
}

// A persisted quote produced by the W10.1 line-item proposer (LLM-match /
// engine-price). One opportunity can have multiple drafts (re-runs, follow-up
// revisions) — read sites pick the current one via `orderBy: createdAt desc`.
//
// `generationContext` freezes the opportunity inputs the proposer saw (requestType,
// deliverableHints, urgency, catalog/rule counts) so a draft is reproducible and
// feeds the year-2 self-improvement story (compare AI-proposed vs owner-final lines
// via each line's `wasEditedByUser`).
model QuoteDraft {
  id                String           @id @default(uuid()) @db.Uuid
  organizationId    String           @db.Uuid
  opportunityId     String           @db.Uuid
  status            QuoteDraftStatus @default(DRAFT)
  // Snapshot of the opportunity context used at generation time (JSON object).
  generationContext Json
  // FK to the AICall that ran the proposer. SetNull on AICall retention purge so a
  // cleanup never cascade-deletes product data; null when the AICall persist failed.
  aiCallId          String?          @db.Uuid
  // Timestamp the quote was sent (PDF attached to a reply, W10.4). Null until then.
  sentAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity  Opportunity     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  aiCall       AICall?         @relation("QuoteDraftAICall", fields: [aiCallId], references: [id], onDelete: SetNull)
  lineItems    QuoteLineItem[]

  // Fast "latest draft for this opp" lookup (detail view + W10.3 editor).
  @@index([opportunityId, createdAt(sort: Desc)])
  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([aiCallId])
}

// A single line on a persisted quote. Price/name/unit/VAT are DENORMALIZED off the
// originating CatalogItem / PricingRule so deleting those source rows never breaks
// quote history (see CatalogItem note). `catalogItemId` / `appliedRuleId` are soft
// references (no FK) kept only for the provenance display.
model QuoteLineItem {
  id              String          @id @default(uuid()) @db.Uuid
  quoteDraftId    String          @db.Uuid
  // 0-based display order on the quote; owner can reorder in W10.3.
  position        Int
  description     String          @db.Text
  // Unit label (matches CatalogItemUnit values, e.g. "hour", "square_meter", "flat_fee").
  unit            String
  quantity        Decimal         @db.Decimal(12, 2)
  // Null when the AI proposed an inferred line with no price — owner sets it (W10.3).
  unitPriceEur    Decimal?        @db.Decimal(10, 2)
  // VAT rate as integer percentage (0 / 9 / 21).
  vatRate         Int             @default(21)
  source          QuoteLineSource
  // Soft references (no FK — source rows may be deleted; denormalized fields above
  // preserve history). Drive the provenance display in the editor.
  catalogItemId   String?         @db.Uuid
  appliedRuleId   String?         @db.Uuid
  // Human-readable provenance note (rule description, or "stel prijs in" for inferred).
  note            String?         @db.Text
  // Flips true on first owner edit (W10.3). Year-2: % of AI lines kept unmodified.
  wasEditedByUser Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  quoteDraft QuoteDraft @relation(fields: [quoteDraftId], references: [id], onDelete: Cascade)

  @@index([quoteDraftId, position])
}
